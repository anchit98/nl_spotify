# Inherited from repo-root .env
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key
GROQ_API_KEY=your_groq_api_key

# Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Skip the executive-summary Groq call (default: false)
SKIP_EXECUTIVE_SUMMARY=false

# Safety margin on daily quota (default 5%)
GROQ_RATE_LIMIT_SAFETY_MARGIN=0.05
