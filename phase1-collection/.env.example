# Supabase (Project Settings -> API)
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key
# Optional: used later if you mint custom JWTs for elevated access
SUPABASE_JWT_SECRET=

# Initial one-time extract: how far back to look (default 90 days / ~3 months)
INITIAL_LOOKBACK_DAYS=90

# Ad-hoc pulls (dashboard button or workflow_dispatch): last N days only (default 7)
ADHOC_LOOKBACK_DAYS=7

# Comma-separated list; omit a source to skip it
ENABLED_SOURCES=app_store,google_play,reddit,community_forum,social_media

# Public Reddit JSON requires a descriptive User-Agent (no API keys needed)
REDDIT_USER_AGENT=nl-spotify-collector/1.0 (public collection; contact: your-email@example.com)

# Spotify app identifiers (defaults shown)
SPOTIFY_APP_STORE_ID=324684580
SPOTIFY_PLAY_STORE_ID=com.spotify.music
