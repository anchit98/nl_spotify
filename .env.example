# Copy to .env for local development (never commit .env).
# Production: set these in Render (backend) and Vercel (frontend) instead.

# --- Supabase (Project Settings → API) ---
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key
# Optional — only if you mint custom JWTs
SUPABASE_JWT_SECRET=

# --- Groq (synthesis + PM Buddy) ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
SKIP_EXECUTIVE_SUMMARY=false
GROQ_RATE_LIMIT_SAFETY_MARGIN=0.05

# --- Backend CORS (comma-separated production origins) ---
CORS_ORIGINS=http://localhost:3000
# Optional — allows Vercel preview URLs (recommended for production)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Phase 1 collection ---
INITIAL_LOOKBACK_DAYS=90
ADHOC_LOOKBACK_DAYS=7
ENABLED_SOURCES=app_store,google_play,reddit,community_forum,social_media
REDDIT_USER_AGENT=nl-spotify-collector/1.0 (public collection; contact: you@example.com)
SPOTIFY_APP_STORE_ID=324684580
SPOTIFY_PLAY_STORE_ID=com.spotify.music

# --- Phase 6 deploy / CI ---
APP_ENV=development
# EXPECTED_SUPABASE_PROJECT_REF=your_project_ref

# --- Phase 5 operations (monitoring + alerts) ---
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
PROMPT_VERSION=2026-06-v1

# --- Frontend (Vercel only — prefix with NEXT_PUBLIC_) ---
# NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com
