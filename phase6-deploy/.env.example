# Used by Phase 6 CI/smoke scripts (inherit from repo-root .env locally)

SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Post-deploy smoke (workflow_dispatch)
STAGING_API_URL=https://nl-spotify-api-staging.onrender.com
PRODUCTION_API_URL=https://nl-spotify-api.onrender.com
STAGING_FRONTEND_URL=https://nl-spotify-staging.vercel.app

# Must match backend APP_ENV and Supabase project (edge case 6.3)
APP_ENV=production
EXPECTED_SUPABASE_PROJECT_REF=your_project_ref
