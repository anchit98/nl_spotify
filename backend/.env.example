# Inherited from repo-root .env
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000

# Optional — allow Vercel preview deploys (recommended in production)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Required for PM Buddy chat and synthesis triggers
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
