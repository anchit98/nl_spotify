# Inherited from repo-root .env
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PROJECT_ANON_KEY=your_anon_key

# Optional — Slack/Discord/generic webhook for failure and drift alerts
ALERT_WEBHOOK_URL=

# Groq model expected in production (must match phase3 GROQ_MODEL)
GROQ_MODEL=llama-3.3-70b-versatile

# Prompt version tag — bump when phase3 prompts change materially
PROMPT_VERSION=2026-06-v1
